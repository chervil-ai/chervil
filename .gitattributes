# Normalize line endings: store text as LF in the repo, check out native on each OS.
* text=auto eol=lf

# Explicit text types (kept LF in the repo regardless of platform).
*.js   text eol=lf
*.mjs  text eol=lf
*.cjs  text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
.env.example text eol=lf
.gitignore   text eol=lf

# Binary assets — never normalize or diff as text.
*.jpg  binary
*.jpeg binary
*.png  binary
*.gif  binary
*.webp binary
*.ico  binary
*.pdf  binary
