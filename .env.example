# Copy this file to .env and fill in your key.

# Required: your Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=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

# Optional: override the model. Defaults to claude-sonnet-4-6 (fast).
# For maximum quality at the cost of latency, use claude-opus-4-8.
# PARSLEE_MODEL=claude-sonnet-4-6

# Optional: how hard the model deliberates. Defaults to "low" for snappiness.
# Try "medium" or "high" for richer pages if you don't mind waiting.
# PARSLEE_EFFORT=low

# Optional: which provider to use. Defaults to "claude".
# Set to "ollama" to develop locally for FREE (no Anthropic credits). Note: Ollama
# has no live web access, so pages compose from the model's knowledge (no grounding)
# and Deep Dive does no real research — switch back to "claude" for real grounding.
# PARSLEE_PROVIDER=claude

# Ollama (only used when PARSLEE_PROVIDER=ollama). Requires a running Ollama server
# with the model pulled (e.g.  ollama pull gemma3:4b).
# PARSLEE_OLLAMA_MODEL=gemma3:4b
# PARSLEE_OLLAMA_URL=http://localhost:11434
