# Chervil publish service — configuration

# Port to listen on (default 8787)
PORT=8787

# Public base URL the service is reachable at — used to build returned page URLs.
# Local: http://localhost:8787   Deployed: https://your-domain
PUBLIC_BASE=http://localhost:8787

# Where to store published blobs (default ./data). Use a persistent disk in prod.
# DATA_DIR=/var/lib/chervil-pages

# Bearer token(s) the app must send. Set ONE of these:
#   PUBLISH_TOKEN=a-long-random-string
#   PUBLISH_TOKENS=tokenA,tokenB
# If unset, the service falls back to the dev token "chervil-dev" (local use only).
PUBLISH_TOKEN=chervil-dev
